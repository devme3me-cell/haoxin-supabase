# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
#
# These are the environment variables you need 
# to add in your Zeabur dashboard.
#
# Go to: Zeabur Dashboard → Your Service → Variables
#
# ============================================

# REQUIRED: Neon Database Connection
# Get from: https://console.neon.tech → Your Project → Connection Details
VITE_DATABASE_URL=postgresql://user:password@ep-xxx-xxx.aws.neon.tech/neondb?sslmode=require

# OPTIONAL: Cloudinary Image Storage
# Get from: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# ============================================
# DEPLOYMENT NOTES
# ============================================
#
# 1. Never commit actual credentials to Git
# 2. Add these in Zeabur Variables tab, not in code
# 3. Make sure to click "Redeploy" after adding variables
# 4. Test locally first with .env file before deploying
#
# ============================================
